---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Transfert de fichiers chiffré avec cryptographie post-quantique MLA — zero-knowledge" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100">

    <!-- Ambient background glow -->
    <div class="fixed inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-cyber-950/40 rounded-full blur-[120px]"></div>
    </div>

    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-white/[0.06] bg-gray-950/80 backdrop-blur-md">
      <!-- Accent line -->
      <div class="h-px w-full bg-gradient-to-r from-transparent via-cyber-700/60 to-transparent"></div>

      <div class="mx-auto max-w-4xl px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="flex items-center gap-2 group">
            <span class="text-lg font-bold text-gradient group-hover:opacity-90 transition-opacity">
              MLA-Transfert
            </span>
          </a>
          <span class="hidden sm:inline-flex badge-cyber">
            <span class="w-1.5 h-1.5 rounded-full bg-cyber-400 animate-pulse"></span>
            post-quantique
          </span>
        </div>

        <nav class="flex items-center gap-5">
          <a
            href="/help"
            class="text-sm text-gray-400 hover:text-gray-100 transition-colors duration-150"
          >
            Aide
          </a>
          <div class="flex items-center gap-3 pl-5 border-l border-white/[0.06]">
            <img src="/logo_anssi.webp" alt="ANSSI" class="h-7 opacity-80 hover:opacity-100 transition-opacity" />
            <img src="/RD_KODETIS-noir.png" alt="Kodetis" class="h-7 invert opacity-70 hover:opacity-90 transition-opacity" />
          </div>
        </nav>
      </div>
    </header>

    <!-- Main -->
    <main class="relative mx-auto max-w-4xl px-6 py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-auto border-t border-white/[0.04] py-6">
      <div class="mx-auto max-w-4xl px-6 flex items-center justify-between text-xs text-gray-600">
        <span>Chiffrement client-side · Zero-knowledge · Données jamais vues par le serveur</span>
        <a href="/help#faq" class="hover:text-gray-400 transition-colors">FAQ</a>
      </div>
    </footer>

  </body>
</html>
