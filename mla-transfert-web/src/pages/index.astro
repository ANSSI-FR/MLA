---
import Layout from '../layouts/Layout.astro';
import SendForm from '../components/SendForm';
---

<Layout title="MLA-Transfert — Envoi sécurisé">
  <div class="animate-slide-up space-y-10">

    <!-- Hero -->
    <div class="text-center space-y-4">
      <h2 class="text-4xl font-bold tracking-tight">
        Envoyez vos fichiers<br />
        <span class="text-gradient">en toute sécurité</span>
      </h2>
      <p class="text-gray-400 max-w-md mx-auto leading-relaxed">
        Chiffrement post-quantique MLA directement dans votre navigateur.
        Le serveur ne voit jamais vos données.
      </p>
    </div>

    <!-- Form card -->
    <div class="card p-8 animate-slide-up" style="animation-delay:0.05s">
      <SendForm client:load />
    </div>

  </div>
</Layout>
